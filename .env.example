# Environment Variables
# Copy this file to .env and fill in the values.
# Do NOT commit .env to version control.

# ──────────────────────────────────────────────
# Contact Form Backend (optional)
# Set to a Formspree, Netlify Forms, or custom
# Cloudflare Worker endpoint.
# Example: https://formspree.io/f/xzyabc
# ──────────────────────────────────────────────
PUBLIC_CONTACT_FORM_ENDPOINT=

# ──────────────────────────────────────────────
# Analytics (optional)
# Uncomment and fill in for your preferred provider
# ──────────────────────────────────────────────

# Plausible Analytics
# PUBLIC_PLAUSIBLE_DOMAIN=yourdomain.com
# PUBLIC_PLAUSIBLE_SCRIPT_URL=https://plausible.io/js/script.js

# Umami Analytics
# PUBLIC_UMAMI_SCRIPT_URL=https://your-umami-instance/script.js
# PUBLIC_UMAMI_WEBSITE_ID=xxxx-xxxx-xxxx-xxxx
