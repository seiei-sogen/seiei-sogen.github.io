# Security Headers for Cloudflare Pages
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-XSS-Protection: 1; mode=block
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://va.vercel-scripts.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https: blob:; font-src 'self' https://fonts.gstatic.com data:; connect-src 'self' https:; frame-src 'self' https://cal.com;
  Permissions-Policy: accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

# Cache Control — Static Assets (1 year)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Cache Control — Fonts (1 year)
/node_modules/@fontsource-variable/*
  Cache-Control: public, max-age=31536000, immutable

# Cache Control — Favicon & Manifest (1 week)
/favicon.svg
/site.webmanifest
  Cache-Control: public, max-age=604800

# Cache Control — HTML Pages (revalidate on every request)
/*.html
  Cache-Control: public, max-age=0, must-revalidate
