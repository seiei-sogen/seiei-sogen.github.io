---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getEntry, render } from 'astro:content';
import { Icon } from 'astro-icon/components';

const entry = await getEntry('changelog', 'history');
if (!entry) {
  return Astro.redirect('/404');
}

const { Content } = await render(entry);
---

<BaseLayout title="Changelog | Historial de Cambios">
  <div class="mx-auto max-w-3xl px-4 py-20">
    <!-- Header -->
    <div class="reveal mb-16 flex flex-col items-center gap-3 text-center">
      <div class="flex items-center gap-3">
        <Icon name="ph:git-merge-duotone" class="h-7 w-7 text-primary/60" />
        <h1
          class="text-4xl font-black tracking-tighter md:text-5xl"
          transition:name="changelog-title"
        >
          Changelog
        </h1>
      </div>
      <p class="text-base text-muted-foreground">
        La evolución constante de nuestra plantilla, documentada paso a paso.
      </p>
    </div>

    <!-- Timeline -->
    <div class="changelog-content reveal relative delay-100">
      <Content />
    </div>
  </div>
</BaseLayout>

<style is:global>
  /* ────────────────────────────────────────────── */
  /*  Timeline spine                                  */
  /* ────────────────────────────────────────────── */
  .changelog-content {
    @apply relative pl-10;
  }

  .changelog-content::before {
    content: '';
    @apply absolute bottom-0 left-[11px] top-4 w-px bg-border/20;
  }

  /* ────────────────────────────────────────────── */
  /*  Version headers (h2)                            */
  /* ────────────────────────────────────────────── */
  .changelog-content h2 {
    @apply relative mt-12 pt-4 first:mt-0;
  }

  /* Timeline dot */
  .changelog-content h2::before {
    content: '';
    @apply absolute -left-[33px] top-[22px] h-[9px] w-[9px] rounded-full bg-primary;
    box-shadow:
      0 0 0 5px hsl(var(--background)),
      0 0 0 6px hsl(var(--border) / 0.1);
  }

  /* Gradient rule under h2 */
  .changelog-content h2::after {
    content: '';
    @apply mb-6 mt-3 block h-px bg-gradient-to-r from-border/20 to-transparent;
  }

  /* ────────────────────────────────────────────── */
  /*  Category labels (h3)                            */
  /* ────────────────────────────────────────────── */
  .changelog-content h3 {
    @apply mb-3 mt-6 flex items-center gap-2.5 text-[11px] font-bold uppercase tracking-[0.15em] text-muted-foreground/50;
  }

  /* Colored accent dot */
  .changelog-content h3::before {
    content: '';
    @apply h-1.5 w-1.5 shrink-0 rounded-full bg-primary/30;
  }

  /* Extending line */
  .changelog-content h3::after {
    content: '';
    @apply h-px flex-1 bg-border/10;
  }

  /* ────────────────────────────────────────────── */
  /*  Lists                                           */
  /* ────────────────────────────────────────────── */
  .changelog-content ul {
    @apply mb-6 list-none space-y-1.5 pl-0;
  }

  .changelog-content li {
    @apply relative pl-4 text-[13px] leading-relaxed text-foreground/60;
  }

  .changelog-content li::before {
    content: '';
    @apply absolute left-0 top-[7px] h-1 w-1 rounded-full bg-primary/20;
  }

  .changelog-content li strong {
    @apply font-semibold text-foreground/85;
  }

  .changelog-content li code {
    @apply rounded border border-border/10 bg-secondary/40 px-1 py-0.5 font-mono text-[11px] text-primary/70;
  }

  /* ────────────────────────────────────────────── */
  /*  Horizontal rules (version separators)           */
  /* ────────────────────────────────────────────── */
  .changelog-content hr {
    @apply my-14 h-px border-none bg-gradient-to-r from-transparent via-border/15 to-transparent;
  }

  /* ────────────────────────────────────────────── */
  /*  Intro paragraph                                 */
  /* ────────────────────────────────────────────── */
  .changelog-content > p:first-of-type {
    @apply mb-8 text-center text-sm italic text-muted-foreground/50;
  }
</style>
