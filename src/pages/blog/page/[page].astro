---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { t } from '@/i18n';
import PostCard from '@/components/cards/PostCard.astro';
import { Icon } from 'astro-icon/components';
import { siteConfig } from '@/site-config';
import ContentPagination from '@/components/navigation/ContentPagination.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  const sortedPosts = allPosts
    .filter(post => !post.data.draft)
    .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

  const perPage = siteConfig.content.postsPerPage;
  const totalPages = Math.ceil(sortedPosts.length / perPage);

  return Array.from({ length: totalPages }, (_, i) => i + 2).map((page) => {
    const start = (page - 1) * perPage;
    const paginatedPosts = sortedPosts.slice(start, start + perPage);
    return {
      params: { page: page.toString() },
      props: {
        posts: paginatedPosts,
        currentPage: page,
        totalPages,
      },
    };
  });
}

interface Props {
  posts: any[];
  currentPage: number;
  totalPages: number;
}

const { posts, currentPage, totalPages } = Astro.props;
---

<BaseLayout title={`Blog | Página ${currentPage}`}>
  <div class="flex flex-col gap-12 py-12 max-w-6xl mx-auto">
    <div class="flex flex-col gap-4 max-w-2xl">
      <h1 class="text-4xl font-bold tracking-tight text-foreground">
        {t('blog.title_main')} <span class="text-muted-foreground">{t('blog.title_highlight')}</span>
      </h1>
      <p class="text-lg text-muted-foreground">
        {t('pagination.page')} {currentPage} {t('pagination.of')} {totalPages}.
      </p>
    </div>

    <div class="flex flex-col gap-12">
      {posts.length > 0 ? (
        posts.map((post) => (
          <PostCard post={post} />
        ))
      ) : (
        <div class="py-24 text-center border border-dashed border-border rounded-[2rem] flex flex-col items-center gap-4">
          <Icon name="ph:pencil-line-duotone" class="w-8 h-8 text-muted-foreground/40 animate-pulse" />
          <p class="text-muted-foreground font-mono text-sm uppercase tracking-widest">{t('blog.no_posts')}</p>
        </div>
      )}
    </div>

    <ContentPagination
      currentPage={currentPage}
      totalPages={totalPages}
      collection="blog"
    />
  </div>
</BaseLayout>
