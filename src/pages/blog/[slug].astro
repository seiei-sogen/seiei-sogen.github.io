---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { t } from '@/i18n';
import ReadingProgress from '@/components/navigation/ReadingProgress.astro';
import ContentHeader from '@/components/ui/ContentHeader.astro';
import PostAuthor from '@/components/ui/PostAuthor.astro';
import ContentPagination from '@/components/navigation/ContentPagination.astro';
import NewsletterWide from '@/components/ui/NewsletterWide.astro';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const posts = await getCollection('blog');
const sortedPosts = posts
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const { post } = Astro.props;
const currentIndex = sortedPosts.findIndex((p) => p.id === post.id);
const prevPost = currentIndex > 0 ? sortedPosts[currentIndex - 1] : null;
const nextPost = currentIndex < sortedPosts.length - 1 ? sortedPosts[currentIndex + 1] : null;

const { Content } = await render(post);
const { title, date, summary } = post.data;
---

<BaseLayout title={`${title} | Blog`} description={summary} articleDate={date}>
  <ReadingProgress />

  <article class="flex flex-col gap-12 max-w-6xl mx-auto py-12 md:py-24">
    <!-- Header -->
    <ContentHeader 
      title={title}
      description={summary}
      backUrl="/blog"
      backText={t('common.back_blog')}
      id={post.id}
      type="blog"
    />
    
    <PostAuthor date={date} readTime="~5 min" />
  </header>

    <!-- MDX Content -->
    <div class="prose dark:prose-invert prose-stone max-w-3xl
      prose-headings:tracking-tighter prose-headings:font-extrabold prose-headings:text-foreground
      prose-p:leading-loose prose-p:text-foreground/80
      prose-li:leading-loose
      prose-a:text-primary prose-a:font-bold prose-a:no-underline hover:prose-a:underline
      prose-blockquote:border-primary prose-blockquote:bg-primary/10 prose-blockquote:py-1 prose-blockquote:px-6 prose-blockquote:rounded-r-xl
      transition-all">
      <Content />
    </div>

    <!-- Footer of the post -->
    <footer class="mt-12 flex flex-col gap-12">
      <ContentPagination 
        prev={prevPost} 
        next={nextPost} 
        collection="blog" 
      />

      <NewsletterWide />
    </footer>
  </article>
</BaseLayout>
