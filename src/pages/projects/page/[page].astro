---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProjectCard from '@/components/cards/ProjectCard.astro';
import { getCollection } from 'astro:content';
import { t } from '@/i18n';
import { Icon } from 'astro-icon/components';
import { siteConfig } from '@/site-config';
import ContentPagination from '@/components/navigation/ContentPagination.astro';

export async function getStaticPaths() {
  const allProjects = await getCollection('projects');
  const sortedProjects = allProjects.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

  const perPage = siteConfig.content.projectsPerPage;
  const totalPages = Math.ceil(sortedProjects.length / perPage);

  return Array.from({ length: totalPages }, (_, i) => i + 2).map((page) => {
    const start = (page - 1) * perPage;
    const paginatedProjects = sortedProjects.slice(start, start + perPage);
    return {
      params: { page: page.toString() },
      props: {
        projects: paginatedProjects,
        currentPage: page,
        totalPages,
      },
    };
  });
}

interface Props {
  projects: any[];
  currentPage: number;
  totalPages: number;
}

const { projects, currentPage, totalPages } = Astro.props;
---

<BaseLayout title={`プロジェクト | ${currentPage} ページ目`}>
  <div class="flex flex-col gap-12 py-12 max-w-6xl mx-auto">
    <div class="flex flex-col gap-4 max-w-2xl">
      <h1 class="text-4xl font-bold tracking-tight text-foreground">
        {t('projects.title_main')} <span class="text-muted-foreground">{t('projects.title_highlight')}</span>
      </h1>
      <p class="text-lg text-muted-foreground">
        {t('pagination.page')} {currentPage} {t('pagination.of')} {totalPages}.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {projects.length > 0 ? (
        projects.map((project) => (
          <ProjectCard project={project} />
        ))
      ) : (
        <div class="col-span-full py-24 text-center border border-dashed border-border rounded-[2rem] flex flex-col items-center gap-4">
          <Icon name="ph:hammer-duotone" class="w-8 h-8 text-muted-foreground/40 animate-pulse" />
          <p class="text-muted-foreground font-mono text-sm italic uppercase tracking-widest">{t('projects.no_page')}</p>
        </div>
      )}
    </div>

    <ContentPagination
      currentPage={currentPage}
      totalPages={totalPages}
      collection="projects"
    />
  </div>
</BaseLayout>
