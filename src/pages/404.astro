---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { t } from '@/i18n';
import Button from '@/components/ui/Button.astro';
import { Icon } from 'astro-icon/components';
---

<BaseLayout title="Página No Encontrada | 404" noIndex={true}>
  <main class="min-h-[70vh] flex flex-col items-center justify-center text-center gap-12 animate-in fade-in duration-1000">
    <!-- Visual Element -->
    <div class="relative group">
      <div class="absolute inset-0 bg-primary/20 blur-[100px] rounded-full scale-150 group-hover:bg-primary/30 transition-all duration-1000"></div>
      <h1 class="text-[10rem] md:text-[15rem] font-black tracking-tighter leading-none select-none relative z-10 text-foreground/10 group-hover:text-foreground/20 transition-all duration-1000">
        404
      </h1>
      <div class="absolute inset-0 flex items-center justify-center z-20">
        <Icon name="ph:ghost-duotone" class="w-24 h-24 text-primary animate-bounce-slow" />
      </div>
    </div>

    <!-- Text Content -->
    <div class="flex flex-col gap-6 max-w-lg relative z-30">
      <h2 class="text-3xl md:text-5xl font-extrabold tracking-tight">{t('404.title')}</h2>
      <p class="text-xl text-muted-foreground leading-relaxed">
        {t('404.description')}
      </p>
    </div>

    <!-- Actions -->
    <div class="flex flex-col sm:flex-row gap-4 relative z-30">
      <Button href="/" variant="primary" size="lg">
        {t('404.back')}
      </Button>
      <Button href="/#contact" variant="ghost" size="lg">
        {t('404.contact')}
      </Button>
    </div>
  </main>
</BaseLayout>

<style>
  @keyframes bounce-slow {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-20px); }
  }
  .animate-bounce-slow {
    animation: bounce-slow 4s infinite ease-in-out;
  }
</style>
