---
import { ClientRouter } from 'astro:transitions';
import Header from '@/components/navigation/Header.astro';
import Footer from '@/components/navigation/Footer.astro';
import Background from '@/components/ui/Background.astro';
import SEO from '@/components/ui/SEO.astro';
import ThemePicker from '@/components/navigation/ThemePicker.astro';
import BuyBanner from '@/components/ui/BuyBanner.astro';
import CustomCursor from '@/components/navigation/CustomCursor.astro';
import { siteConfig } from '../site-config';
import '@/styles/global.css';

// Fontsource (Local Fonts — zero external requests, full privacy)
import '@fontsource-variable/inter';
import '@fontsource-variable/roboto-mono';

interface Props {
  title: string;
  description?: string;
  image?: string | undefined;
  articleDate?: Date;
  noIndex?: boolean;
  extraJsonLd?: Record<string, any> | Record<string, any>[];
}

const {
  title,
  description = siteConfig.seo.defaultDescription,
  image = siteConfig.seo.ogImage,
  articleDate,
  noIndex = false,
  extraJsonLd = [],
} = Astro.props;
---

<!doctype html>
<html lang={siteConfig.site.lang} class="dark">
  <head>
    <SEO
      title={title}
      description={description}
      image={image}
      noIndex={noIndex}
      extraJsonLd={extraJsonLd}
      {...articleDate ? { articleDate } : {}}
    />

    {siteConfig.ui.enableViewTransitions && <ClientRouter />}

    <!-- Google Analytics... -->

    <!-- Theme Selection Persistence (Critical: prevent FOUC) -->
    <script
      is:inline
      define:vars={{
        defaultLightPrimary: siteConfig.ui.brandColor.light.primary,
        defaultLightForeground: siteConfig.ui.brandColor.light.foreground,
        defaultDarkPrimary: siteConfig.ui.brandColor.dark.primary,
        defaultDarkForeground: siteConfig.ui.brandColor.dark.foreground,
        themeAllowToggle: siteConfig.theme.allowToggle,
        themeDefaultMode: siteConfig.theme.defaultMode,
      }}
    >
      (function (lp, lf, dp, df, allowToggle, defaultMode) {
        const setTheme = () => {
          // 1. Handle Dark/Light Class
          let theme;

          if (allowToggle) {
            // Usuario puede elegir: localStorage > preferencia del sistema
            theme =
              localStorage.getItem('theme') ||
              (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
          } else {
            // Toggle bloqueado: forzar defaultMode, ignorar preferencias
            theme = defaultMode;
            // Limpiar localStorage para evitar conflicto si cambian después
            localStorage.removeItem('theme');
          }

          if (theme === 'light') {
            document.documentElement.classList.remove('dark');
          } else {
            document.documentElement.classList.add('dark');
          }

          // 2. Handle Custom Brand Colors
          const lightPrimary = localStorage.getItem('user-primary-color-light') || lp;
          const lightForeground = localStorage.getItem('user-primary-foreground-light') || lf;
          const darkPrimary = localStorage.getItem('user-primary-color-dark') || dp;
          const darkForeground = localStorage.getItem('user-primary-foreground-dark') || df;

          const root = document.documentElement;
          root.style.setProperty('--brand-primary-light', lightPrimary);
          root.style.setProperty('--brand-foreground-light', lightForeground);
          root.style.setProperty('--brand-primary-dark', darkPrimary);
          root.style.setProperty('--brand-foreground-dark', darkForeground);
        };

        // Run immediately
        setTheme();

        // Run after view transition swap
        document.addEventListener('astro:after-swap', setTheme);
      })(
        defaultLightPrimary,
        defaultLightForeground,
        defaultDarkPrimary,
        defaultDarkForeground,
        themeAllowToggle,
        themeDefaultMode
      );
    </script>
  </head>
  <body
    class="min-h-screen bg-transparent font-sans text-foreground antialiased selection:bg-primary/20"
  >
    <Background />
    {siteConfig.ui.showBuyBanner && <BuyBanner />}
    <div
      class:list={['relative flex min-h-screen flex-col', siteConfig.ui.showBuyBanner && 'pt-10']}
    >
      {siteConfig.ui.showThemePicker && <ThemePicker />}
      <Header />

      <main class="flex-1 transition-all duration-500">
        <div class="container mx-auto max-w-6xl px-4 py-12 sm:px-8">
          <slot />
        </div>
      </main>

      <Footer />
    </div>

    {siteConfig.ui.enableCustomCursor && <CustomCursor />}

    <!-- Scroll Reveal & Magnetic Scripts (deferred — not critical for first paint) -->
    <script>
      function initReveal() {
        const observerOptions = {
          root: null,
          rootMargin: '0px',
          threshold: 0.1,
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('active');
              observer.unobserve(entry.target);
            }
          });
        }, observerOptions);

        const revealElements = document.querySelectorAll('.reveal');
        revealElements.forEach((el) => {
          const rect = el.getBoundingClientRect();
          const inViewport = rect.top < window.innerHeight && rect.bottom > 0;
          if (inViewport) {
            el.classList.add('active');
          } else {
            observer.observe(el);
          }
        });
      }

      function initMagnetic() {
        const magnets = document.querySelectorAll('.magnetic');

        magnets.forEach((magnet) => {
          if (!(magnet instanceof HTMLElement)) return;

          magnet.addEventListener('mousemove', (e: MouseEvent) => {
            const position = magnet.getBoundingClientRect();
            const x = e.clientX - position.left - position.width / 2;
            const y = e.clientY - position.top - position.height / 2;

            magnet.style.transform = `translate(${x * 0.35}px, ${y * 0.35}px)`;
            magnet.style.transition = 'transform 0.1s ease-out';
          });

          magnet.addEventListener('mouseleave', () => {
            magnet.style.transform = 'translate(0px, 0px)';
            magnet.style.transition = 'transform 0.5s cubic-bezier(0.23, 1, 0.32, 1)';
          });
        });
      }

      // Defer until after first paint to reduce main-thread work during load
      function initAfterPaint() {
        if ('requestIdleCallback' in window) {
          requestIdleCallback(() => {
            initReveal();
            initMagnetic();
          });
        } else {
          setTimeout(() => {
            initReveal();
            initMagnetic();
          }, 500);
        }
      }

      // Run after initial load and after each view transition
      document.addEventListener('astro:page-load', initAfterPaint);
    </script>
  </body>
</html>
