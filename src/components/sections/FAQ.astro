---
import { getCollection } from 'astro:content';
import { t } from '@/i18n';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import FAQItem from '@/components/ui/FAQItem.astro';

const faqs = await getCollection('faq');
const sortedFaqs = faqs.sort((a, b) => a.data.order - b.data.order);
---

<section class="py-32 border-t border-border/60" id="faq">
  <div class="container px-4 sm:px-8 max-w-6xl mx-auto flex flex-col gap-20">
    <SectionHeader
      title={t('faq.title')}
      subtitle={t('faq.subtitle')}
    />

    <div class="flex flex-col gap-6 max-w-5xl mx-auto w-full">
      {sortedFaqs.map((item) => (
        <FAQItem 
          question={item.data.question} 
          answer={item.data.answer} 
        />
      ))}
    </div>
  </div>
</section>

<style>
  /* Removing default arrows in different browsers */
  summary::-webkit-details-marker {
    display: none;
  }
</style>
