---
import { t } from '@/i18n';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import Badge from '@/components/ui/Badge.astro';

const techStack = [
  "Astro", "TypeScript", "React", "Next.js", "Tailwind CSS", "Node.js", "Hono", "Cloudflare", "PostgreSQL"
];
---
<section class="py-24 border-t border-border/40 overflow-hidden">
  <div class="flex flex-col gap-8">
    <SectionHeader
      title={t('stack.title')}
      subtitle={t('stack.subtitle')}
    />

    <div class="flex flex-wrap gap-3 justify-center md:justify-start ring-1 ring-border/20 p-8 rounded-3xl bg-muted/5">
      {techStack.map((tech) => (
        <Badge class="h-12 px-6 normal-case text-sm border border-border/40 hover:border-primary/20 hover:bg-secondary transition-all cursor-default">
          {tech}
        </Badge>
      ))}
    </div>
  </div>
</section>
