---
interface Props {
  variant?: 'primary' | 'secondary' | 'outline' | 'ghost';
  class?: string;
}

const { 
  variant = 'secondary', 
  class: className 
} = Astro.props;

const variants = {
  primary: 'bg-primary text-primary-foreground',
  secondary: 'bg-secondary text-secondary-foreground',
  outline: 'border border-border text-foreground',
  ghost: 'bg-transparent text-muted-foreground opacity-70',
};
---

<span
  class:list={[
    'inline-flex items-center rounded-full px-2.5 py-0.5 text-[10px] font-medium font-mono uppercase tracking-widest',
    variants[variant],
    className
  ]}
>
  <slot />
</span>
