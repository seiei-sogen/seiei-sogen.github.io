---
import type { HTMLAttributes } from 'astro/types';

export interface Props extends HTMLAttributes<'div'> {
  as?: string;
}

const { 
  as: Element = 'div', 
  class: className, 
  ...rest 
} = Astro.props;
---

<Element
  class:list={[
    'flex flex-col gap-4 p-6 rounded-3xl border border-border/60 bg-card hover:border-border/80 transition-all shadow-sm hover:shadow-xl hover:shadow-primary/5',
    className
  ]}
  {...rest}
>
  <slot />
</Element>
