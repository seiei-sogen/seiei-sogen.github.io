---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'outline' | 'ghost';
  size?: 'sm' | 'md' | 'lg' | 'xl';
  isMagnetic?: boolean;
  class?: string;
  [x: string]: unknown;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  isMagnetic = variant !== 'ghost',
  class: className,
  ...rest
} = Astro.props;

const variants = {
  primary: 'bg-primary text-primary-foreground hover:opacity-90 shadow-lg shadow-primary/10',
  secondary: 'bg-secondary text-secondary-foreground hover:bg-secondary/80 shadow-sm',
  outline: 'border border-border bg-transparent hover:bg-muted text-foreground',
  ghost: 'bg-transparent hover:bg-muted/50 text-muted-foreground hover:text-foreground',
};

const sizes = {
  sm: 'h-8 px-4 text-xs',
  md: 'h-11 px-8 text-sm',
  lg: 'h-12 px-10 text-base',
  xl: 'h-16 px-12 text-lg font-bold',
};

const Element = href ? 'a' : 'button';
---

<Element
  href={href}
  class:list={[
    'inline-flex items-center justify-center rounded-full font-medium transition-colors active:scale-95 disabled:pointer-events-none disabled:opacity-50',
    isMagnetic && 'magnetic',
    variants[variant],
    sizes[size],
    className,
  ]}
  {...rest}
>
  <slot />
</Element>
