---
import Badge from './Badge.astro';

interface Props {
  role: string;
  company: string;
  period: string;
  description: string;
}

const { role, company, period, description } = Astro.props;
---

<div class="relative pl-8 pb-12 last:pb-0 group reveal">
  <div class="absolute -left-[5.5px] top-1.5 h-3 w-3 rounded-full border-2 border-primary bg-background transition-all duration-500 group-hover:bg-primary group-hover:scale-125 shadow-[0_0_0_0_rgba(var(--primary),0.4)] group-hover:shadow-[0_0_15px_2px_rgba(var(--primary),0.4)]" />
  
  <div class="flex flex-col md:flex-row md:items-baseline md:justify-between gap-1">
    <h3 class="text-xl md:text-2xl font-bold text-foreground tracking-tight">{role}</h3>
    <Badge variant="secondary" class="normal-case opacity-70 group-hover:opacity-100 transition-opacity">
      {period}
    </Badge>
  </div>
  
  <p class="text-primary font-bold mb-3 tracking-tight text-lg">{company}</p>
  <p class="text-base text-muted-foreground max-w-xl leading-relaxed text-balance">
    {description}
  </p>
</div>
