---
interface Props {
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
  class?: string;
}

const { 
  title, 
  subtitle, 
  align = 'left', 
  class: className 
} = Astro.props;
---

<div class:list={[
  'flex flex-col gap-2',
  align === 'center' ? 'items-center text-center' : 'items-start text-left',
  className
]}>
  <h2 class="text-2xl font-bold tracking-tight">{title}</h2>
  {subtitle && <p class="text-sm text-muted-foreground max-w-xl">{subtitle}</p>}
</div>
