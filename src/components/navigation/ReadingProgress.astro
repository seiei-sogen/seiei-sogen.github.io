<!-- Reading Progress Bar -->
<div 
  id="progress-bar" 
  class="fixed top-0 left-0 h-1 bg-primary z-[70] transition-all duration-150 ease-out w-0 shadow-[0_0_10px_rgba(var(--primary),0.5)]"
  role="progressbar"
  aria-valuemin="0"
  aria-valuemax="100"
  aria-valuenow="0"
></div>

<script>
  function setupProgress() {
    const progressBar = document.getElementById('progress-bar');
    if (!progressBar) return;

    window.addEventListener('scroll', () => {
      const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
      const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
      const scrolled = (winScroll / height) * 100;
      progressBar.style.width = scrolled + "%";
      progressBar.setAttribute('aria-valuenow', Math.round(scrolled).toString());
    });
  }

  // Initial setup
  setupProgress();
  
  // Support for View Transitions
  document.addEventListener('astro:page-load', setupProgress);
</script>
